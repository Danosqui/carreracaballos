@startuml 02_seleccionar_jugador
title Seleccionar jugador activo

actor "Vista" as V
participant "JugadorController" as JC
participant "JugadorService" as JS
participant "JugadorDAO" as JD

== Listar jugadores existentes ==

V -> JC : listarJugadores()
activate JC
JC -> JS : listarJugadores()
activate JS
JS -> JD : listarJugadores()
activate JD
JD --> JS : List<Jugador>
deactivate JD
JS --> JC : List<Jugador>
deactivate JS
JC --> V : List<Jugador>
deactivate JC

== Marcar jugador como activo ==

alt el usuario eligio uno de la lista (por referencia)
    V -> JC : seleccionarJugador(jugador)
    activate JC
    note right of JC
      Solo guarda la referencia interna
      en jugadorSeleccionado
    end note
    JC --> V
    deactivate JC

else el usuario lo identifico por nombre/mail
    V -> JC : seleccionarJugador(nombre, mail)
    activate JC

    JC -> JS : buscarJugador(nombre, mail)
    activate JS
    JS -> JD : buscarJugador(nombre)
    activate JD
    JD --> JS : Jugador o null
    deactivate JD

    alt jugador encontrado y mail coincide
        JS --> JC : jugador
    else no existe o el mail no coincide
        JS --> JC : null
    end
    deactivate JS

    alt jugador != null
        note right of JC : guarda referencia interna
        JC --> V
    else jugador == null
        JC --> V : RuntimeException("Jugador no encontrado")
    end
    deactivate JC
end

@enduml
